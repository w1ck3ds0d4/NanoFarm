{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Reinstall NanoFarm extension",
      "detail": "Build VSIX and install into the current VS Code. Reload window after.",
      "type": "shell",
      "command": "pnpm",
      "args": ["--filter", "nanofarm-extension", "reinstall"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": ["$tsc"]
    }
  ]
}
