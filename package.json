    "game",
    "idle",
    "simulation",
    "city-builder",
    "pixijs",
    "vscode",
    "vscode-extension",
    "claude",
    "claude-code"
  ],
  "homepage": "https://github.com/w1ck3ds0d4/NanoFarm#readme",
  "bugs": {
    "url": "https://github.com/w1ck3ds0d4/NanoFarm/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/w1ck3ds0d4/NanoFarm.git"
  },
  "author": "w1ck3ds0d4 <daniel.svs@outlook.com>",
  "license": "AGPL-3.0-or-later",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @nanofarm/app dev",
    "build": "pnpm --filter @nanofarm/app build",
    "preview": "pnpm --filter @nanofarm/app preview",
    "typecheck": "pnpm -r typecheck"
  }
}
