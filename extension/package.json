{
  "name": "nanofarm-extension",
  "displayName": "NanoFarm",
  "description": "Tiny SimCity-style idle game in a VS Code tab. Build a city, run a real production chain, climb a tech tree, and let your Claude Code tool calls feed bonus materials.",
  "version": "0.1.0",
  "private": true,
  "publisher": "w1ck3ds0d4",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/w1ck3ds0d4/NanoFarm#readme",
  "bugs": {
    "url": "https://github.com/w1ck3ds0d4/NanoFarm/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/w1ck3ds0d4/NanoFarm.git",
    "directory": "extension"
  },
  "author": "w1ck3ds0d4 <daniel.svs@outlook.com>",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": [
    "game",
    "idle",
    "city-builder",
    "simulation",
    "pixijs",
    "claude",
    "claude-code"
  ],
  "main": "./out/extension.js",
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "nanofarm.open",
        "title": "NanoFarm: Open Game",
        "category": "NanoFarm"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . -w",
    "typecheck": "tsc -p . --noEmit",
    "build": "pnpm --filter @nanofarm/app build && pnpm compile",
    "bundle-dist": "node ./scripts/bundle-dist.mjs",
    "package": "pnpm build && pnpm bundle-dist && vsce package --no-dependencies",
    "reinstall": "pnpm package && code --install-extension nanofarm-extension-0.1.0.vsix --force"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "typescript": "~5.6.3"
  },
  "dependencies": {
    "@nanofarm/shared": "workspace:*"
  }
}
